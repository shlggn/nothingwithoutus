# YouTube Data API v3 Key
# Get your free API key from: https://console.cloud.google.com/apis/credentials
# Enable YouTube Data API v3 in your Google Cloud Project
VITE_YOUTUBE_API_KEY=YOUR_API_KEY_HERE

# YouTube Channel/Playlist IDs for each category
# Featured Journeys - Replace with your actual playlist or channel ID
VITE_FEATURED_JOURNEYS_PLAYLIST_ID=YOUR_PLAYLIST_ID_HERE

# Long-Form Conversations - Replace with your actual playlist or channel ID  
VITE_LONG_FORM_PLAYLIST_ID=YOUR_PLAYLIST_ID_HERE

# Firebase Configuration
# Copy these to .env.local and replace with your actual Firebase credentials
# Get these values from Firebase Console > Project Settings > General > Your apps > Web app
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

